/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model combined with a global administrator role.
 * User data is heavily siloed, ensuring that a user can only ever access their own information and content.
 *
 * Data Structure: All user-generated data (profiles, content, captures, notes) is nested within a top-level
 * `/users/{userId}` collection. This path-based ownership is the primary mechanism for authorization, making rules
 * simple, performant, and secure. Global data like `/genres` and `/roles_admin` exist at the root level.
 *
 * Key Security Decisions:
 * - User data is private by default. Access is restricted to the document owner or an administrator.
 * - The top-level `/users` collection cannot be listed to prevent user enumeration.
 * - An administrator role is granted by the existence of a document in the `/roles_admin/{userId}` collection. Admins have read-only access to all user data and write access to global collections.
 * - The `/genres` collection is public for reading but writable only by administrators.
 * - The `/content_genres` join collection is locked down because its schema lacks a `userId` field, making it impossible to securely determine ownership of the relationship. This must be fixed in the data model.
 *
 * Denormalization for Authorization: The rules rely on path-based ownership (`/users/{userId}/...`) to avoid slow and costly `get()` calls for most operations. For role-based access, an `/roles_admin` collection is used, where the existence of a document grants privileges, which is highly performant.
 *
 * Structural Segregation: Private user data is strictly separated into user-specific subcollections. Publicly readable data (`/genres`) and administrative data (`/roles_admin`) are in their own top-level collections. This separation clarifies access control and enhances security for list operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user is the owner of a document,
     * based on a provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the currently authenticated user has administrator privileges.
     * Admin status is granted by the existence of a document in the /roles_admin collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     * @allow A user creating their own profile: (create) auth.uid == userId
     * @allow An admin reading another user's profile: (get) isAdmin() == true
     * @deny A user trying to view another user's profile: (get) auth.uid != userId
     * @principle Restricts access to a user's own data tree and allows self-creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId) && resource != null;

      /**
       * @description Manages a user's private collection of content items.
       * @path /users/{userId}/content/{contentId}
       * @allow A user creating a new content item in their own library: (create) auth.uid == userId
       * @allow An admin viewing a user's content: (get, list) isAdmin() == true
       * @deny A user trying to delete content from another user's library: (delete) auth.uid != userId
       * @principle Enforces path-based ownership for all nested user data.
       */
      match /content/{contentId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isOwner(userId) && resource != null && request.resource.data.userId == resource.data.userId;
        allow delete: if isOwner(userId) && resource != null;

        /**
         * @description Manages screenshots uploaded by a user for a specific content item.
         * @path /users/{userId}/content/{contentId}/captures/{captureId}
         * @allow A user adding a screenshot to their own content: (create) auth.uid == userId
         * @allow An admin viewing a user's screenshot: (get, list) isAdmin() == true
         * @deny A user updating another user's screenshot: (update) auth.uid != userId
         * @principle Enforces path-based ownership inherited from the parent user document.
         */
        match /captures/{captureId} {
          allow get: if isOwner(userId) || isAdmin();
          allow list: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId) && request.resource.data.userId == userId;
          allow update: if isOwner(userId) && resource != null && request.resource.data.userId == resource.data.userId;
          allow delete: if isOwner(userId) && resource != null;
        }

        /**
         * @description Manages notes created by a user for a specific content item.
         * @path /users/{userId}/content/{contentId}/notes/{noteId}
         * @allow A user adding a note to their own content: (create) auth.uid == userId
         * @allow An admin viewing a user's note: (get, list) isAdmin() == true
         * @deny A user deleting another user's note: (delete) auth.uid != userId
         * @principle Enforces path-based ownership inherited from the parent user document.
         */
        match /notes/{noteId} {
          allow get: if isOwner(userId) || isAdmin();
          allow list: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId);
          allow update: if isOwner(userId) && resource != null;
          allow delete: if isOwner(userId) && resource != null;
        }
      }
    }

    /**
     * @description Manages the global list of genres.
     * @path /genres/{genreId}
     * @allow Any user, signed in or not, reading the list of genres: (get, list) always permitted
     * @allow An admin creating a new genre: (create) isAdmin() == true
     * @deny A regular user trying to delete a genre: (delete) isAdmin() == false
     * @principle Provides public read access for global data while restricting writes to administrators.
     */
    match /genres/{genreId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Manages admin role assignments.
     * @path /roles_admin/{userId}
     * @allow An admin checking if another user is an admin: (get) isAdmin() == true
     * @allow An admin adding a new admin: (create) isAdmin() == true
     * @deny A regular user trying to see the list of admins: (list) isAdmin() == false
     * @principle Secures role management, allowing only existing admins to view or modify roles.
     */
    match /roles_admin/{userId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Manages the join table between content and genres.
     * @path /content_genres/{contentGenreId}
     * @allow No operations are permitted directly on this collection.
     * @deny A user trying to create a link for their content: (create) is denied.
     * @deny Any user trying to read the collection: (get, list) is denied.
     * @principle Denies all access due to a schema issue. Writes cannot be secured without a 'userId' field on the document to verify ownership of the content being linked.
     */
    match /content_genres/{contentGenreId} {
      // CRITICAL: Cannot implement owner-only writes. The 'ContentGenre' entity is missing a 'userId' field.
      // This field is required to validate that the user creating the link actually owns the 'contentId' they are referencing.
      // Until the schema is updated, all write access must be denied to prevent unauthorized data associations.
      allow get: if false;
      allow list: if false;
      allow create: if false; // TODO: Add owner validation once the schema is updated with a 'userId' field.
      allow update: if false;
      allow delete: if false; // TODO: Add owner validation once the schema is updated with a 'userId' field.
    }
  }
}
